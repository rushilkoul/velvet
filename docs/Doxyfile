# github pages doxyfile

PROJECT_NAME           = "Velvet"
PROJECT_NUMBER         = "0.1a"
PROJECT_BRIEF          = "A beginner-friendly C++ GUI framework built on SFML."

OUTPUT_DIRECTORY       = docs/site
HTML_OUTPUT            = html

CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO

INPUT                  = include \
                         docs
FILE_PATTERNS          = *.hpp \
                         *.h \
                         *.hh \
                         core \
                         *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/*

USE_MDFILE_AS_MAINPAGE = docs/mainpage.md
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
IMAGE_PATH             = docs
HTML_EXTRA_STYLESHEET  = docs/custom.css

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

GENERATE_HTML          = YES
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO

HIDE_UNDOC_RELATIONS   = NO
HAVE_DOT               = NO

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
