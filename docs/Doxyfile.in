# Doxygen configuration for Velvet

PROJECT_NAME           = "Velvet"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "A beginner-friendly C++ GUI framework built on SFML"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"

CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO

INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/include" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/docs"
FILE_PATTERNS          = *.hpp \
                         *.h \
                         *.hh \
                         core \
                         *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/*

USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md"
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
IMAGE_PATH             = "@CMAKE_CURRENT_SOURCE_DIR@/docs"
HTML_EXTRA_STYLESHEET  = "@CMAKE_CURRENT_SOURCE_DIR@/docs/custom.css"

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO

HIDE_UNDOC_RELATIONS   = NO
HAVE_DOT               = NO

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"
